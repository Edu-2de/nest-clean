# @name create_question
POST {{basUrl}}/questions
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "title": "nova pergunta 6",
  "content": "conteúdo"
}

###

# @name fetch_recent_questions
GET {{basUrl}}/questions
Content-Type: application/json
Authorization: Bearer {{authToken}}
